# Server
PORT=5000
MONGO_URI=mongodb://localhost:27017/enggstack2

# Auth
JWT_SECRET=change_this_to_any_long_random_string

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# OpenAI (platform.openai.com)
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY

# Gmail for OTP emails (use App Password, NOT your real password)
# Get App Password: myaccount.google.com -> Security -> 2-Step -> App Passwords
GMAIL_USER=youremail@gmail.com
GMAIL_PASS=xxxx xxxx xxxx xxxx

# Frontend URL
CLIENT_URL=https://engg-stack-qol8.vercel.app
